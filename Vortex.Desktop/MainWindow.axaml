<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Vortex.Desktop.MainWindow"
        Width="1180" Height="760"
        MinWidth="860" MinHeight="560"
        Title="Vortex AI Assistant">
  <Window.Background>
    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#101213" Offset="0" />
      <GradientStop Color="#15172E" Offset="1" />
    </LinearGradientBrush>
  </Window.Background>
  <Grid ColumnDefinitions="260,*,300" RowDefinitions="64,*" Margin="14">
    <Border Grid.RowSpan="2" Grid.Column="0" Background="#181B34" CornerRadius="20" Padding="16" Margin="0,0,12,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Spacing="12">
          <TextBlock Text="Vortex" FontSize="28" FontWeight="Bold" Foreground="#F8FAFC" />
          <TextBlock Text="Dağıtık AI Assistant" Foreground="#94A3B8" />
          <Button Content="+ Yeni sohbet" Command="{Binding NewChatCommand}" />
          <TextBox Watermark="Sohbet ara" Text="{Binding SearchText}" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Spacing="8">
          <TextBlock Text="Plan / Kota" FontWeight="SemiBold" Foreground="#CBD5E1" />
          <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="#94A3B8" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Background="#1B1E3A" CornerRadius="18" Padding="18" Margin="0,0,0,12">
      <DockPanel>
        <TextBlock Text="Vortex Desktop → Backend → Model Router → Official AI API" Foreground="#CBD5E1" FontSize="16" VerticalAlignment="Center" />
        <Button DockPanel.Dock="Right" Content="Bağlan" Command="{Binding ConnectCommand}" />
      </DockPanel>
    </Border>

    <Border Grid.Column="1" Grid.Row="1" Background="#111428" CornerRadius="20" Padding="16" Margin="0,0,12,0">
      <Grid RowDefinitions="*,Auto">
        <ScrollViewer Grid.Row="0">
          <ItemsControl ItemsSource="{Binding Messages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#202447" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                  <StackPanel Spacing="6">
                    <TextBlock Text="{Binding Role}" Foreground="#8BE9FD" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#F8FAFC" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,14,0,0">
          <TextBox Grid.Column="0" Text="{Binding InputText}" Watermark="Mesaj yazın..." AcceptsReturn="True" MinHeight="48" />
          <Button Grid.Column="1" Margin="10,0,0,0" Content="🎙" Command="{Binding PushToTalkCommand}" />
          <Button Grid.Column="2" Margin="10,0,0,0" Content="Gönder" Command="{Binding SendCommand}" />
        </Grid>
      </Grid>
    </Border>

    <Border Grid.Column="2" Grid.Row="1" Background="#181B34" CornerRadius="20" Padding="16">
      <StackPanel Spacing="14">
        <TextBlock Text="Sağ Panel" FontSize="20" FontWeight="Bold" Foreground="#F8FAFC" />
        <TextBlock Text="Aktif model" Foreground="#94A3B8" />
        <TextBlock Text="{Binding ActiveModel}" Foreground="#F8FAFC" />
        <TextBlock Text="Local Agent" Foreground="#94A3B8" />
        <TextBlock Text="127.0.0.1:47891 / güvenli araç arayüzü" TextWrapping="Wrap" Foreground="#CBD5E1" />
        <TextBlock Text="Dosya ve proje bağlamı" Foreground="#94A3B8" />
        <Border Background="#202447" CornerRadius="14" Padding="12">
          <TextBlock Text="İlk derlenebilir sürümde servis sözleşmeleri ve güvenlik sınırları hazır." TextWrapping="Wrap" />
        </Border>
      </StackPanel>
    </Border>
  </Grid>
</Window>
