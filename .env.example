# Vortex development configuration
# Never commit real provider API keys.

ASPNETCORE_ENVIRONMENT=Development
VORTEX_SERVER_URL=http://127.0.0.1:5000
VORTEX_LOCAL_AGENT_URL=http://127.0.0.1:47891
VORTEX_ADMIN_URL=http://127.0.0.1:47892

# Use a 32+ character random value in real deployments.
JWT__SIGNINGKEY=change-me-development-only-signing-key-32

# Provider keys are server-side only. Prefer a secret manager in production.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com
OPENAI_COMPATIBLE_API_KEY=
