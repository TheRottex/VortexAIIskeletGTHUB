@page "/desktop/authorize"
@model Vortex.Web.Pages.DesktopAuthorizeModel
@{
    ViewData["Title"] = "Vortex Desktop Yetkilendirme";
}
<section class="auth-card">
    <h1>Vortex Desktop bağlantısı</h1>
    <p>Bu işlem Vortex Desktop uygulamasının hesabınıza güvenli şekilde bağlanmasını sağlar. Parolanız uygulamaya gönderilmez.</p>
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage)) { <div class="error">@Model.ErrorMessage</div> }
    <form method="post">
        <input type="hidden" asp-for="SessionId" />
        <input type="hidden" asp-for="State" />
        <button type="submit">Vortex uygulamasına dön</button>
    </form>
    <p><a href="/logout">Çıkış yap</a></p>
</section>
<style>body{margin:0;background:linear-gradient(135deg,#101213,#15172E);color:#eef2ff;font-family:Inter,Segoe UI,sans-serif}.auth-card{max-width:520px;margin:10vh auto;padding:34px;background:#181b34;border-radius:22px}button{width:100%;padding:13px;border:0;border-radius:14px;background:#8be9fd;color:#08111a;font-weight:700}.error{padding:12px;background:#7f1d1d;border-radius:12px}</style>
