@page "/desktop/success"
@model Vortex.Web.Pages.DesktopSuccessModel
@{
    ViewData["Title"] = "Giriş başarılı";
}
<section class="auth-card">
    <h1>Giriş başarılı</h1>
    <p>Giriş başarılı. Artık işleminize Vortex uygulamasından devam edebilirsiniz.</p>
    <p>Uygulama otomatik açılmazsa <a href="@Model.CallbackUrl">buraya tıklayın</a>.</p>
</section>
<script>
setTimeout(function(){ window.location.href = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CallbackUrl)); }, 900);
</script>
<style>body{margin:0;background:linear-gradient(135deg,#101213,#15172E);color:#eef2ff;font-family:Inter,Segoe UI,sans-serif}.auth-card{max-width:560px;margin:12vh auto;padding:34px;background:#181b34;border-radius:22px}a{color:#8be9fd}</style>
